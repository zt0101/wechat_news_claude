.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 城市 + 分类头部 */
.city-header {
  background: #fff;
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.city-selector {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.city-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.city-arrow {
  font-size: 24rpx;
  color: #999;
}

.local-tabs {
  display: flex;
  gap: 32rpx;
}

.ltab {
  font-size: 28rpx;
  color: #666;
  padding-bottom: 6rpx;
}

.ltab-active {
  color: #fe2c55;
  font-weight: 600;
  border-bottom: 3rpx solid #fe2c55;
}

/* 新闻列表 */
.list-scroll {
  flex: 1;
}

.news-list {
  padding: 12rpx 0;
}

.news-item {
  background: #fff;
  margin-bottom: 2rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.item-left {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 30rpx;
  color: #1a1a1a;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.item-meta {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.meta-text {
  font-size: 22rpx;
  color: #bbb;
}

.meta-dot {
  font-size: 22rpx;
  color: #ddd;
  margin: 0 6rpx;
}

.item-thumb {
  width: 200rpx;
  height: 150rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.no-more {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  padding: 32rpx 0;
}
