<view class="page">
  <swiper
    class="news-swiper"
    vertical
    duration="300"
    current="{{currentIndex}}"
    bindchange="onSwiperChange"
    skip-hidden-item-layout
  >
    <swiper-item wx:for="{{newsList}}" wx:key="id">
      <view class="slide">

        <!-- 顶部安全区：撑开状态栏 + 胶囊按钮 -->
        <view class="safe-top" style="height: {{capsuleBottom + 12}}px"></view>

        <!-- 图片区域：横向轮播，类目标签叠在左上角 -->
        <view class="img-wrap">
          <swiper
            class="img-swiper"
            current="{{item.imgIndex}}"
            bindchange="onImgSwiperChange"
            data-news-index="{{index}}"
          >
            <swiper-item wx:for="{{item.images}}" wx:for-item="imgUrl" wx:key="*this">
              <image class="slide-img" src="{{imgUrl}}" mode="aspectFill" lazy-load />
            </swiper-item>
          </swiper>
          <!-- 类目标签：图片左上角 -->
          <view class="cat-tag cat-{{item.categoryKey}}">{{item.category}}</view>
        </view>

        <!-- 分页点点：图片和标题之间 -->
        <view class="dots-bar">
          <view
            class="dot {{item.imgIndex === dotIdx ? 'dot-active' : ''}}"
            wx:for="{{item.images}}"
            wx:for-index="dotIdx"
            wx:for-item="dotItem"
            wx:key="*this"
          ></view>
        </view>

        <!-- 底部文字区（白底，标题在图片下方）-->
        <view class="info-area">
          <text class="slide-title">{{item.title}}</text>
          <view class="meta-row">
            <text class="slide-source">{{item.source}}</text>
            <view class="action-row">
              <view class="action-item" bindtap="onLike" data-index="{{index}}">
                <text class="action-icon {{item.liked ? 'icon-liked' : ''}}">♥</text>
                <text class="action-count">{{item.likesText}}</text>
              </view>
              <view class="action-item" bindtap="onComment" data-id="{{item.id}}">
                <text class="action-icon">评</text>
                <text class="action-count">{{item.commentsText}}</text>
              </view>
              <view class="action-item" bindtap="onShare" data-id="{{item.id}}">
                <text class="action-icon">转</text>
                <text class="action-count">{{item.sharesText}}</text>
              </view>
            </view>
          </view>
          <view class="detail-btn" bindtap="onDetail" data-id="{{item.id}}">
            <text class="detail-text">阅读详情</text>
            <text class="detail-arrow">›</text>
          </view>
        </view>

        <!-- 底部安全区：Tab Bar 占位 -->
        <view class="safe-bottom"></view>
      </view>
    </swiper-item>
  </swiper>
</view>
