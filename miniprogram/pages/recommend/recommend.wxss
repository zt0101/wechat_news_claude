.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 搜索栏 */
.header {
  background: #fff;
  padding: 16rpx 24rpx;
}

.search-box {
  height: 68rpx;
  background: #f2f2f2;
  border-radius: 34rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-ph {
  color: #bbb;
  font-size: 26rpx;
}

/* 分类 Tab */
.cat-scroll {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  white-space: nowrap;
  flex-shrink: 0;
}

.cat-list {
  display: flex;
  padding: 0 8rpx;
}

.cat-item {
  display: inline-flex;
  align-items: center;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
  position: relative;
  flex-shrink: 0;
}

.cat-active {
  color: #fe2c55;
  font-weight: 600;
}

.cat-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: #fe2c55;
  border-radius: 2rpx;
}

/* 瀑布流 */
.waterfall-scroll {
  flex: 1;
  overflow: hidden;
}

.waterfall {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 12rpx;
  align-items: flex-start;
}

.col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 新闻卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}

.img-box {
  position: relative;
}

.card-img {
  width: 100%;
  display: block;
}

/* 类目标签 */
.cat-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.cat-tech     { background: rgba(22, 119, 255, 0.9); }
.cat-finance  { background: rgba(0, 185, 107, 0.9); }
.cat-ent      { background: rgba(146, 84, 222, 0.9); }
.cat-hot      { background: rgba(245, 34, 45, 0.9); }
.cat-sport    { background: rgba(250, 140, 22, 0.9); }
.cat-society  { background: rgba(0, 180, 216, 0.9); }
.cat-intl     { background: rgba(19, 194, 194, 0.9); }

/* 卡片内容 */
.card-body {
  padding: 16rpx;
}

.card-title {
  font-size: 26rpx;
  color: #1a1a1a;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.card-src {
  font-size: 22rpx;
  color: #bbb;
}

.card-likes {
  font-size: 22rpx;
  color: #fe2c55;
}

.no-more {
  text-align: center;
  color: #ccc;
  font-size: 24rpx;
  padding: 32rpx 0;
}
