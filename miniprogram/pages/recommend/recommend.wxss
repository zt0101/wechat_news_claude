.page {
  height: 100vh;
  background: #e8e8e8;
  overflow: hidden;
}

/* 堆叠容器：撑满全屏，touch 事件挂在这里 */
.stack-root {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

/* 每张卡片：绝对定位，left/right 撑满，top 由 inline style 驱动 */
.card-wrap {
  position: absolute;
  left: 0;
  right: 0;
}

/* 卡片内容：圆角上边，白底，flex 纵向 */
.card-inner {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.12);
}

/* 顶部安全区：高度 = 胶囊按钮底部 + 12px，黑色背景 */
.safe-top {
  flex-shrink: 0;
  background: #1a1a1a;
}

/* 图片容器：占满所有剩余空间 */
.img-wrap {
  flex: 1;
  position: relative;
  overflow: hidden;
  min-height: 0;
}

/* 横向图片轮播：填满 img-wrap */
.img-swiper {
  width: 100%;
  height: 100%;
}

.slide-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 类目标签：图片左上角 */
.cat-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  z-index: 1;
}

.cat-tech     { background: rgba(22, 119, 255, 0.88); }
.cat-finance  { background: rgba(0, 185, 107, 0.88); }
.cat-ent      { background: rgba(146, 84, 222, 0.88); }
.cat-hot      { background: rgba(245, 34, 45, 0.88); }
.cat-sport    { background: rgba(250, 140, 22, 0.88); }
.cat-society  { background: rgba(0, 180, 216, 0.88); }
.cat-intl     { background: rgba(19, 194, 194, 0.88); }

/* 分页点点：图片与标题之间 */
.dots-bar {
  flex-shrink: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 0 6rpx;
  background: #fff;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #e0e0e0;
}

.dot-active {
  width: 28rpx;
  border-radius: 6rpx;
  background: #fe2c55;
}

/* 底部信息区 */
.info-area {
  flex-shrink: 0;
  background: #fff;
  padding: 24rpx 28rpx 16rpx;
}

/* 标题：限 2 行 */
.slide-title {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 34rpx;
  color: #1a1a1a;
  font-weight: 600;
  line-height: 1.55;
  margin-bottom: 18rpx;
}

/* 来源 + 互动按钮：同一行，两端对齐 */
.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.slide-source {
  font-size: 24rpx;
  color: #999;
  flex: 1;
  min-width: 0;
}

/* 互动按钮组 */
.action-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  flex-shrink: 0;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 28rpx;
  color: #aaa;
}

.icon-liked {
  color: #fe2c55;
}

.action-count {
  font-size: 24rpx;
  color: #aaa;
}

/* 阅读详情按钮 */
.detail-btn {
  margin-top: 20rpx;
  height: 80rpx;
  background: #fe2c55;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.detail-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.detail-arrow {
  color: #fff;
  font-size: 36rpx;
  line-height: 1;
}
